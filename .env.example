DEBUG=True

# Database Configuration
DATABASE_USERNAME=username
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wwa_db
DATABASE_DBAPI=postgresql+asyncpg

MIGRATE=True
MAX_MIGRATION_RETRIES=5
MIGRATION_INITIAL_DELAY=3
MIGRATION_MAX_DELAY=30

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=10
REDIS_URL=redis://localhost:6379/0

# NATS Configuration
NATS_URL=nats://localhost:4222
NATS_TOKEN=the-nats-token